          "cookies": [],
          "content": {
            "size": 5286,
            "mimeType": "application/json",
            "text": "{\"status\":0,\"data\":{\"items\":[{\"id\":5466139,\"ch_name\":\"208 后招\",\"uid\":1891017,\"content\":\"在现实历史富平之战前，李彦先已经战死，所守陕州已失。南宋总指挥为短于用兵的张浚急于转守为攻，拒纳曲端按兵据险，先行防御，待一、二年后再进行反攻的建策，并将其罢免。\",\"praise_num\":13,\"un_praise_num\":0,\"create_time\":\"2026-05-04 22:29:20\",\"reply_to\":0,\"reply_root\":0,\"del\":0,\"sub_comments_count\":0,\"hasPraised\":false,\"hasUnPraised\":false,\"self\":false,\"need_block\":false,\"user\":{\"id\":1891017,\"username\":\"海洋馆\",\"cover\":1},\"sub_comments\":[]},{\"id\":5466161,\"ch_name\":\"208 后招\",\"uid\":1891017,\"content\":\"而在富平之战中，张浚拉了五路宋军18万人，以刘锡为都统制，拒绝吴玠建议移据高地（即小说里立寨策略），认为自己人数占优，就选择在芦苇沼泽后立寨，同时运输辎重的乡民在寨外围再立小寨（脑溢血行为1）\",\"praise_num\":13,\"un_praise_num\":0,\"create_time\":\"2026-05-04 22:38:12\",\"reply_to\":0,\"reply_root\":0,\"del\":0,\"sub_comments_count\":0,\"hasPraised\":false,\"hasUnPraised\":false,\"self\":false,\"need_block\":false,\"user\":{\"id\":1891017,\"username\":\"海洋馆\",\"cover\":1},\"sub_comments\":[]},{\"id\":5466219,\"ch_name\":\"208 后招\",\"uid\":1891017,\"content\":\"兀术接战书后选择不答复示弱，等到娄室带4-5万金军汇合。娄室登山看宋军营盘，发现破绽百出，却仍旧坚垒不出。张浚误为金军怯战，开始如同203话一样互飚垃圾话（没错那个一头驴的赏格是真的，只是对象是张浚）\",\"praise_num\":13,\"un_praise_num\":0,\"create_time\":\"2026-05-04 23:05:53\",\"reply_to\":0,\"reply_root\":0,\"del\":0,\"sub_comments_count\":0,\"hasPraised\":false,\"hasUnPraised\":false,\"self\":false,\"need_block\":false,\"user\":{\"id\":1891017,\"username\":\"海洋馆\",\"cover\":1},\"sub_comments\":[]},{\"id\":5466188,\"ch_name\":\"208 后招\",\"uid\":1891017,\"content\":\"此时对面金军只有四太子金兀术2万人，张浚却不听众将建议先趁娄室军未至前先动手，反而执意给对面下战书约战（脑溢血2，此时打过去，金军若守城或者野战，宋军有机会吃掉两万人，就算对面避战也能拿下城据城而守）\",\"praise_num\":12,\"un_praise_num\":0,\"create_time\":\"2026-05-04 22:51:53\",\"reply_to\":0,\"reply_root\":0,\"del\":0,\"sub_comments_count\":0,\"hasPraised\":false,\"hasUnPraised\":false,\"self\":false,\"need_block\":false,\"user\":{\"id\":1891017,\"username\":\"海洋馆\",\"cover\":1},\"sub_comments\":[]},{\"id\":5466250,\"ch_name\":\"208 后招\",\"uid\":1891017,\"content\":\"到了开战时，刘锡先派千把人去试探性进攻，被全歼了（毕竟平地上跑不过对面骑兵，相比之下漫画里乔泽部还能利用地利跑回来）\",\"praise_num\":12,\"un_praise_num\":0,\"create_time\":\"2026-05-04 23:22:38\",\"reply_to\":0,\"reply_root\":0,\"del\":0,\"sub_comments_count\":0,\"hasPraised\":false,\"hasUnPraised\":false,\"self\":false,\"need_block\":false,\"user\":{\"id\":1891017,\"username\":\"海洋馆\",\"cover\":1},\"sub_comments\":[]},{\"id\":5466263,\"ch_name\":\"208 后招\",\"uid\":1891017,\"content\":\"紧接着到了中午，娄室让完颜折合带三千精骑用土袋把沼泽填出一条路，突袭宋寨外围运辎重乡民的小寨，驱民入宋军营。同时由于刘锡没高地视野（木制高台应该不够看这么大营盘）没法指挥，直接就乱了，五路大军各自为战\",\"praise_num\":12,\"un_praise_num\":0,\"create_time\":\"2026-05-04 23:28:36\",\"reply_to\":0,\"reply_root\":0,\"del\":0,\"sub_comments_count\":0,\"hasPraised\":false,\"hasUnPraised\":false,\"self\":false,\"need_block\":false,\"user\":{\"id\":1891017,\"username\":\"海洋馆\",\"cover\":1},\"sub_comments\":[]},{\"id\":5466655,\"ch_name\":\"208 后招\",\"uid\":1891017,\"content\":\"经常在户外活动的人都知道，多云无雨不晒又凉爽（想想穿着重甲在烈日下暴晒，很要命的），我骑车最喜欢这种天气\",\"praise_num\":9,\"un_praise_num\":0,\"create_time\":\"2026-05-05 04:27:57\",\"reply_to\":0,\"reply_root\":0,\"del\":0,\"sub_comments_count\":0,\"hasPraised\":false,\"hasUnPraised\":false,\"self\":false,\"need_block\":false,\"user\":{\"id\":1891017,\"username\":\"海洋馆\",\"cover\":1},\"sub_comments\":[]},{\"id\":5465657,\"ch_name\":\"208 后招\",\"uid\":143637,\"content\":\"真的要开打了！\",\"praise_num\":0,\"un_praise_num\":0,\"create_time\":\"2026-05-04 18:48:46\",\"reply_to\":0,\"reply_root\":0,\"del\":0,\"sub_comments_count\":0,\"hasPraised\":false,\"hasUnPraised\":false,\"self\":false,\"need_block\":false,\"user\":{\"id\":143637,\"username\":\"暗黑\",\"cover\":12},\"sub_comments\":[]},{\"id\":5467115,\"ch_name\":\"208 后招\",\"uid\":1259282,\"content\":\"官家的死亡凝視\",\"praise_num\":0,\"un_praise_num\":0,\"create_time\":\"2026-05-05 12:32:57\",\"reply_to\":0,\"reply_root\":0,\"del\":0,\"sub_comments_count\":0,\"hasPraised\":false,\"hasUnPraised\":false,\"self\":false,\"need_block\":false,\"user\":{\"id\":1259282,\"username\":\"洗臉盆\",\"cover\":14},\"sub_comments\":[]},{\"id\":5467202,\"ch_name\":\"208 后招\",\"uid\":2047438,\"content\":\"官家的弓箭已經飢渴難耐了。\",\"praise_num\":0,\"un_praise_num\":0,\"create_time\":\"2026-05-05 13:16:55\",\"reply_to\":0,\"reply_root\":0,\"del\":0,\"sub_comments_count\":0,\"hasPraised\":false,\"hasUnPraised\":false,\"self\":false,\"need_block\":false,\"user\":{\"id\":2047438,\"username\":\"略懂略懂\",\"cover\":1},\"sub_comments\":[]}],\"total\":10,\"country\":\"SG\"},\"msg\":\"success\",\"u\":[]}"
